    "@babel/plugin-proposal-decorators": "7.28.0",
    "@babel/plugin-transform-runtime": "7.28.3",
    "@babel/preset-env": "7.28.3",
    "@babel/register": "7.28.3",
    "@babel/runtime": "7.28.4",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/testing": "^11.1.18",
    "jest": "30.2.0",
    "nodemon": "^3.1.10",
    "prettier": "3.6.2",
    "prisma": "^7.7.0",
    "supertest": "7.1.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json"
