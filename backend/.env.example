# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ridesharing

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY=7d

# ─── Server ──────────────────────────────────────────────
PORT=5000

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
